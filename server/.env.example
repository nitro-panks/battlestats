# Non-secret configuration — copy to .env and adjust as needed.
# Secrets (WG_APP_ID, DB_PASSWORD, DJANGO_SECRET_KEY) go in .env.secrets.

DB_ENGINE="postgresql_psycopg2"
DB_NAME="battlestats"
DB_USER="django"
DB_HOST="db"
DB_PORT="5432"

# Set to "1" in production to enable daily clan crawl schedule
ENABLE_CRAWLER_SCHEDULES="0"

# Comma-separated hostnames/IPs that Django will serve
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,server

# --- Optional tuning (defaults shown) ---

# HOT_ENTITY_PINNED_PLAYER_NAMES=lil_boots
# HOT_ENTITY_PLAYER_LIMIT=20
# HOT_ENTITY_CLAN_LIMIT=10
# CLAN_BATTLE_WARM_CLAN_IDS=
